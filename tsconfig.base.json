{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@signalforge/shared/dist/*": ["packages/shared/dist/*"],
      "@signalforge/shared/*": ["packages/shared/src/*"],
      "@signalforge/shared/src/*": ["packages/shared/src/*"],
      "@signalforge/core/dist/*": ["packages/core/dist/*"],
      "@signalforge/core/*": ["packages/core/src/*"],
      "@signalforge/core/src/*": ["packages/core/src/*"]
    }
  }
}
