{
  "name": "signalforge-native-host",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validation-harness": "ts-node src/runValidationHarness.ts",
    "register:chrome-host": "powershell -ExecutionPolicy Bypass -File ./register-nativehost-windows.ps1 -HostName com.signalforge.host -ManifestTemplateFile com.signalforge.host.json",
    "register:chrome-nativehost": "powershell -ExecutionPolicy Bypass -File ./register-nativehost-windows.ps1 -HostName com.signalforge.nativehost -ManifestTemplateFile native-messaging-host.json"
  },
  "dependencies": {
    "@signalforge/core": "workspace:*",
    "@signalforge/shared": "workspace:*",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
